@{
    ViewData["Title"] = "About";
}

<div class="hero-box">
    <h2>About This Project</h2>
    <p>Learn more about the purpose, features, and technologies used in this system</p>
</div>

<div class="about-grid">

    <div class="about-card">
        <h3>Project Title</h3>
        <p><strong>Local Tourist Day-Visit Planner and Information System</strong></p>
    </div>

    <div class="about-card">
        <h3>Project Objective</h3>
        <p>
            This web application helps local tourists discover places of interest in and around Batticaloa within a 25 km radius of Kattankudy and create a simple one-day visit plan.
        </p>
    </div>

    <div class="about-card">
        <h3>Main Features</h3>
        <ul>
            <li>View tourist places</li>
            <li>Search and filter by category</li>
            <li>View place details and map</li>
            <li>Create a one-day visit plan</li>
            <li>Admin login and place management</li>
        </ul>
    </div>

    <div class="about-card">
        <h3>Technologies Used</h3>
        <ul>
            <li>HTML</li>
            <li>CSS</li>
            <li>C#</li>
            <li>ASP.NET Core MVC</li>
            <li>MySQL</li>
            <li>Visual Studio Code</li>
        </ul>
    </div>

    <div class="about-card">
        <h3>System Users</h3>
        <p><strong>Local Tourist User:</strong> Can browse, search, filter, and plan visits.</p>
        <p><strong>Administrator:</strong> Can add, edit, and delete place information.</p>
    </div>

    <div class="about-card">
        <h3>Developer Details</h3>
        <p><strong>Name:</strong> Manaal SAF</p>
        <p><strong>Project Type:</strong> Individual Academic Project</p>
        <p><strong>Area:</strong> Batticaloa / Kattankudy Local Tourist Planning</p>
    </div>

</div>